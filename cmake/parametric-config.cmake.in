get_filename_component(PARAMETRIC_CMAKE_DIR "${CMAKE_CURRENT_LIST_FILE}" PATH)

if(NOT TARGET @PROJECT_NAME@::@PROJECT_NAME@)
    include("${PARAMETRIC_CMAKE_DIR}/@PROJECT_NAME@-targets.cmake")
endif()

set(PARAMETRIC_LIBRARIES @PROJECT_NAME@::@PROJECT_NAME@)
